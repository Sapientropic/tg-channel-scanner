#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT_DIR"

if [ ! -x "$ROOT_DIR/.venv/bin/python" ] && [ ! -x "$ROOT_DIR/.venv/Scripts/python.exe" ]; then
  echo "First run: preparing T-Sense local dependencies..."
  bash "$ROOT_DIR/setup.sh"
elif [ ! -f "$ROOT_DIR/.tgcs/sources.json" ]; then
  echo "Initializing T-Sense jobs starter defaults..."
  "$ROOT_DIR/tgcs" init --starter jobs
fi

if [ "${TGCS_SIGNAL_DESK_FOREGROUND:-0}" = "1" ]; then
  exec "$ROOT_DIR/tgcs" dashboard --open "$@"
fi

mkdir -p "$ROOT_DIR/output"
echo "Opening Signal Desk in your browser."
echo "Signal Desk will keep running in the background; logs are in output/signal-desk.log."
nohup "$ROOT_DIR/tgcs" dashboard --open "$@" >"$ROOT_DIR/output/signal-desk.log" 2>"$ROOT_DIR/output/signal-desk.err.log" &
echo "$!" > "$ROOT_DIR/output/signal-desk.pid"
disown "$!" 2>/dev/null || true
