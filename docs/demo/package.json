{
  "name": "tg-channel-scanner-demo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx --yes hyperframes@0.5.3 preview",
    "check": "npx --yes hyperframes@0.5.3 lint && npx --yes hyperframes@0.5.3 validate && npx --yes hyperframes@0.5.3 inspect",
    "render": "npx --yes hyperframes@0.5.3 render",
    "publish": "npx --yes hyperframes@0.5.3 publish",
    "report": "python ../../scripts/report.py --input fixtures/demo-scan.jsonl --profile fixtures/demo-profile.md --html-only fixtures/demo-report.md --output renders/demo-report.md",
    "capture": "npm run report && node capture-demo-screenshots.cjs"
  },
  "dependencies": {
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "hyperframes": "^0.5.3"
  }
}
